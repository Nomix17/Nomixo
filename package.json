{
  "name": "nomixo",
  "version": "1.5.0",
  "description": "Stream your favorite movies and shows in one seamless experience",
  "type": "module",
  "author": {
    "name": "Nomix17",
    "url": "https://github.com/Nomix17"
  },
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.2.0",
    "electron-store": "^11.0.2",
    "express": "^5.1.0",
    "webtorrent": "^2.8.4"
  },
  "devDependencies": {
    "electron": "^39.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.nomixo.app",
    "productName": "Nomixo",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/mpv/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/mpv",
        "to": "mpv",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "tar.gz",
        "deb",
        "rpm",
        "AppImage"
      ],
      "artifactName": "Nomixo-v${version}-linux-${arch}.${ext}",
      "category": "AudioVideo",
      "icon": "logo/icon",
      "maintainer": "Nomix17"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo/icon.ico",
      "artifactName": "Nomixo-v${version}-Windows-Portable-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "Nomixo-v${version}-Windows-Installer-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "Nomixo-v${version}-mac.${ext}"
    }
  }
}
